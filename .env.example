# Turso
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Hume AI
HUME_API_KEY=your-hume-api-key
HUME_SECRET_KEY=your-hume-secret-key
HUME_CONFIG_ID=your-evi-config-id

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+12105551234

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HUME_CONFIG_ID=your-hume-config-id
NEXT_PUBLIC_PHONE=(830) 521-7133
NEXT_PUBLIC_PHONE_TEL=+18305217133
NEXT_PUBLIC_BOOKING_URL=https://cal.com/calltide/onboarding
NEXT_PUBLIC_MARKETING_URL=https://calltide.app

# Auth
ADMIN_PASSWORD=your-admin-password
CLIENT_AUTH_SECRET=your-client-auth-secret

# AI Model (optional — defaults to claude-sonnet-4-5-20250929)
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Analytics & Tracking (all optional — only loads if present)
# NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GADS_ID=AW-XXXXXXXXXX
# NEXT_PUBLIC_GADS_ONBOARDING_LABEL=your-onboarding-conversion-label
# NEXT_PUBLIC_GADS_SUBSCRIPTION_LABEL=your-subscription-conversion-label
# NEXT_PUBLIC_HOTJAR_ID=1234567

# Phase 2: Outreach Engine (optional)
GOOGLE_PLACES_API_KEY=your-google-places-api-key
RESEND_API_KEY=your-resend-api-key
OUTREACH_FROM_EMAIL=Calltide <hello@contact.calltide.app>
