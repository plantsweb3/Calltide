# Google (optional — for calendar integration)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Outreach
OUTREACH_FROM_EMAIL=Capta <hello@contact.captahq.com>

# AI Model (optional — defaults to claude-sonnet-4-5-20250929)
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Analytics & Tracking (all optional — only loads if present)
# NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GADS_ID=AW-XXXXXXXXXX
# NEXT_PUBLIC_GADS_ONBOARDING_LABEL=your-onboarding-conversion-label
# NEXT_PUBLIC_GADS_SUBSCRIPTION_LABEL=your-subscription-conversion-label
